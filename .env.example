# Dynasty Manager — Environment Variables
# Copy this file to .env.local and fill in production values before release.

# Sentry crash reporting DSN (optional — omit to disable)
VITE_SENTRY_DSN=

# RevenueCat API key (falls back to test key if not set)
# Use 'appl_xxx' for iOS builds, 'goog_xxx' for Android builds
VITE_REVENUECAT_API_KEY=

# AdMob rewarded ad unit IDs (falls back to Google's test IDs if not set)
VITE_ADMOB_REWARDED_IOS=
VITE_ADMOB_REWARDED_ANDROID=
