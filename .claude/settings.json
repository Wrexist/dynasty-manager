    "deny": [
      "Bash(gh pr create*)",
      "Bash(git add -A*)",
      "Bash(git add .)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf*)",
      "Bash(npm publish*)"
    ]
  }
}
